# Ansible
#
# Ignores files generated by Ansible and its ecosystem (e.g., Molecule, Ansible-lint)
# and common temporary/local files.

# Generic temporary files and logs
.*.swp
*.retry
*.log

# Python temporary files (as Ansible is Python-based)
*.py[co]
__pycache__/

# Directory for Ansible-lint cache (recommended by Ansible-lint docs)
.cache/

# Virtual environment
.venv/
venv/
ENV/
env/
# specific to the vscode-ansible extension
out/
dist/
lib/
include/
local/

# Local configuration files that should not be committed
# (e.g., local-configure.yml, vbox_host.cfg, etc)
local-configure.yml
vbox_host.cfg
# Inventory files for local/testing that might contain sensitive info or be environment specific
# (adjust as needed, standard inventories like `hosts` should usually be tracked)
myhost-*

# Directory for build artifacts/documentation
docs/_build/

# Operating System specific files
.DS_Store # macOS

# Local .terraform directories
.terraform/

# .tfstate files
*.tfstate
*.tfstate.*
# Exclude the lock file which is created and deleted automatically during apply
.terraform/.tfstate.lock.info

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data.
# Do not commit these files to version control.
# *.tfvars
# *.tfvars.json

# Ignore override files, as they are usually used for local development and testing
# and not intended for version control.
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include tfplan files to ignore the plan output of command: terraform plan -out=tfplan
*tfplan*

# Optional: ignore graph output files
# *.dot

# Optional: ignore CLI configuration files
.terraformrc
terraform.rc