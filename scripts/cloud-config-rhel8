#cloud-config
# =============================================================================
# cloud-init user-data — RHEL 8 qcow2 on Nutanix AHV
#
# PURPOSE:
#   Creates a local admin user with SSH key-only authentication.
#   Password login is explicitly disabled — the only way in is via the
#   injected SSH public key.
#
# BEFORE USE — generate a dedicated bastion SSH key pair:
#
#   On your RHEL 8 workspace (or any Linux machine):
#
#     ssh-keygen -t ed25519 -C "rhel8-bastion-key" -f ~/.ssh/bastion_id_ed25519
#
#   On Windows (PowerShell):
#
#     ssh-keygen -t ed25519 -C "rhel8-bastion-key" -f "$env:USERPROFILE\.ssh\bastion_id_ed25519"
#
#   Then copy the PUBLIC key content:
#
#     Linux:   cat ~/.ssh/bastion_id_ed25519.pub
#     Windows: Get-Content "$env:USERPROFILE\.ssh\bastion_id_ed25519.pub"
#
#   Paste the full output (the entire "ssh-ed25519 AAAA... rhel8-bastion-key" line)
#   into the ssh_authorized_keys field below, replacing the placeholder.
#
# NUTANIX NOTES:
#   - Attach this file as "User Data" in the VM creation wizard:
#     VM → Create VM → Guest Customization → Cloud-init → User Data
#   - Nutanix AHV injects this via the ConfigDrive or NoCloud datasource
#   - The RHEL 8 qcow2 must have cloud-init installed (official RHEL 8 cloud
#     images from Red Hat include it by default)
#   - First boot may take 60-90 seconds while cloud-init runs
#
# CONNECTING AFTER BOOT:
#
#   ssh -i ~/.ssh/bastion_id_ed25519 rhel-admin@<nutanix-vm-ip>
#
#   To then SSH from the bastion into cluster nodes using your cluster key,
#   use agent forwarding:
#
#   ssh-add ~/.ssh/bastion_id_ed25519      # load bastion key into agent
#   ssh-add ~/.ssh/rke2_id_ed25519         # load cluster key into agent
#   ssh -A rhel-admin@<nutanix-vm-ip>      # -A forwards both keys into session
#
# =============================================================================

users:
  - name: rhel-admin                          # change to your preferred username
    gecos: "RKE2 Bastion Admin"
    groups: wheel                             # wheel = sudo access on RHEL
    sudo: ALL=(ALL) NOPASSWD:ALL             # passwordless sudo
    shell: /bin/bash
    lock_passwd: true                         # disable password login entirely
    ssh_authorized_keys:
      - "ssh-ed25519 AAAAC3NQOj0m aruse@darksignal.us"  # ← paste your public key here

# Disable SSH password authentication — key only
ssh_pwauth: false

# Lock the root account password (root login already blocked by RHEL default sshd config)
disable_root: true

# Preserve the hostname assigned by Nutanix IPAM,
# or set a static one by uncommenting:
# hostname: bastion-rhel8
preserve_hostname: false

# Final message written to /var/log/cloud-init-output.log on completion
final_message: |
  Cloud-init bootstrap complete.
  User 'rhel-admin' is configured for SSH key-only login.
  Boot took $UPTIME seconds.
  Connect with: ssh -i ~/.ssh/bastion_id_ed25519 rhel-admin@<this-vm-ip>
